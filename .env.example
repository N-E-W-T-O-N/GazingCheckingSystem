# Vercel Environment Variables

# API endpoint for the FastAPI backend
# In development, leave empty to use relative paths (proxied by vite dev server)
# In production on Vercel, set this to your deployed backend URL
# Example: https://api.example.com
VITE_API_URL=

# Optional: Backend host for local development
# This is only used by the Vite dev server proxy
VITE_BACKEND_URL=http://localhost:8000
